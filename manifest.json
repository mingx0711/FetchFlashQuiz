{
  "manifest_version": 3,
  "name": "FLIZ - vocab and top most used sites on newtab, vocabulary tool",
  "version": "1.9.8.6",
  "description": "Looks up words for various languages, Display vocabs & quiz vocabs in new tab, show most used sites in new tab ",
  "permissions": [
    "storage",
    "topSites",
    "*://*.wiktionary.org/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "content_security_policy": {
    "script-src": "'self'",
    "object-src": "'self'"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://en.wiktionary.org/*"
  ]
}