{
  "manifest_version": 3,
  "name": "Instant Dicitionary & Vocabs",
  "version": "1.9.2",
  "description": "Looks up words for various languages, Display&Quiz them in new tab ",
  "permissions": ["storage","*://*.wiktionary.org/*"],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "content_security_policy": {
    "script-src": "'self'",
    "object-src": "'self'"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }, 
  "host_permissions": [
    "https://en.wiktionary.org/*"
  ]

  
}