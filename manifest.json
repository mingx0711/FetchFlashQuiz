{
  "manifest_version": 3,
  "name": "Search Flash Quiz",
  "version": "1.9.5",
  "description": "Looks up words for various languages, Display vocabs & quiz vocabs in new tab ",
  "permissions": ["storage","*://*.wiktionary.org/*"],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "content_security_policy": {
    "script-src": "'self'",
    "object-src": "'self'"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://en.wiktionary.org/*"
  ]
}